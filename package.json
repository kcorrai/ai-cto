    "@octokit/rest": "^22.0.1",
    "@prisma/client": "^6.19.3",
    "@react-email/components": "^1.0.12",
    "@react-pdf/renderer": "^4.5.1",
    "@t3-oss/env-nextjs": "^0.11",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.4.0",
    "@vercel/queue": "^0.3.0",
    "ai": "^6.0.201",
    "clsx": "^2.1.1",
    "framer-motion": "^11",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "lucide-react": "^0.469",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.4",
    "stripe": "^16.12.0",
    "svix": "^1.95.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24"
